# Slack Bot configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token # Required if using Socket Mode

# Search API Configuration (e.g. Google Search API / Custom Real-Time Search)
REALTIME_SEARCH_API_KEY=your-api-key
REALTIME_SEARCH_CX=your-custom-search-engine-id # Optional

# Optional settings
POLL_INTERVAL_SECONDS=300
PORT=3000
